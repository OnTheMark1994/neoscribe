{
  "name": "scribefold-ai",
  "version": "1.0.14",
  "description": "ScribeFold AI - A foldable section text editor with AI assistance built with Electron and React",
  "author": "",
  "private": true,
  "main": "public/electron.js",
  "homepage": "./",
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@reduxjs/toolkit": "^2.11.0",
    "@supabase/supabase-js": "^2.39.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "argon2": "^0.44.0",
    "diff": "^8.0.2",
    "electron-is-dev": "^2.0.0",
    "electron-store": "^8.2.0",
    "monaco-editor": "^0.55.1",
    "monaco-spellchecker": "^0.6.0",
    "node-machine-id": "^1.1.12",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-redux": "^9.2.0",
    "react-scripts": "5.0.1",
    "redux": "^5.0.1",
    "typo-js": "^1.3.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "react-start": "cross-env BROWSER=none react-scripts start",
    "start:web": "react-scripts start",
    "react-build": "react-scripts build",
    "build:web": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron-dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-pack": "npm run react-build && electron-builder",
    "start": "npm run electron-dev",
    "build": "npm run react-build && electron-builder",
    "build:win": "npm run react-build && electron-builder --win",
    "build:mac": "npm run react-build && electron-builder --mac",
    "build:linux": "npm run react-build && electron-builder --linux"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^39.2.6",
    "electron-builder": "^24.13.3",
    "fs-extra": "^11.3.2",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.scribefoldai.app",
    "productName": "ScribeFold AI",
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "files": [
      "build/**/*",
      "public/electron.js",
      "public/preload.js",
      "public/encryption.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "icon": "public/scribefold-ai-icon-256.png",
      "target": "AppImage",
      "category": "Utility",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "AbeApple",
      "repo": "scribefold-ai-monorepo"
    }
  }
}
