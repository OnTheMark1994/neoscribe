# Server Configuration
PORT=3000

# Supabase (for user authentication and database)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# DeepSeek AI API
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Stripe Payment Processing
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Stripe Price IDs (from Stripe Dashboard)
STRIPE_PRICE_ID_LIGHT=price_xxxxx
STRIPE_PRICE_ID_BASIC=price_xxxxx
STRIPE_PRICE_ID_FULL=price_xxxxx
STRIPE_PRICE_ID_HEAVY=price_xxxxx

# Stripe Payment Links (from Stripe Dashboard)
STRIPE_PAYMENT_LINK_LIGHT=https://buy.stripe.com/xxxxx
STRIPE_PAYMENT_LINK_BASIC=https://buy.stripe.com/xxxxx
STRIPE_PAYMENT_LINK_FULL=https://buy.stripe.com/xxxxx
STRIPE_PAYMENT_LINK_HEAVY=https://buy.stripe.com/xxxxx

# Frontend URL (for Stripe redirects)
FRONTEND_URL=https://your-web-portal-url.onrender.com
