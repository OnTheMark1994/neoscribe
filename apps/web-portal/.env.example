# Supabase Configuration (for authentication)
# Note: Create React App requires REACT_APP_ prefix
REACT_APP_SUPABASE_URL=your_supabase_url_here
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# API Server URL (deployed on Render.com)
REACT_APP_API_BASE_URL=https://your-api-server-url.onrender.com

# GitHub Repository for Downloads (format: owner/repo)
REACT_APP_GITHUB_REPO=your-username/scribefold-ai

# Stripe Customer Portal URL (optional - can be set in constants.js)
REACT_APP_STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/xxxxx
