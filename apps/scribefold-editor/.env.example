# ScribeFold Editor Environment Variables
# ========================================

# Supabase Configuration
# ----------------------
# Supabase project URL
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
# Supabase anon/public key
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# API Configuration
# ----------------
# API server URL (for AI chat, auth, etc.)
REACT_APP_SCRIBEFOLD_API_BASE_URL=http://localhost:8080

# Web Portal Configuration
# -----------------------
# Web portal URL (for account management, downloads, etc.)
REACT_APP_WEB_PORTAL_URL=http://localhost:3001
