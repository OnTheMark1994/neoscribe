# Scribefold API Env Variable Example 
# ======================================================

# Server Configuration
# ---------------------
# Port for the API server (default: 8080)
PORT=8080

# Supabase Configuration
# ----------------------
# Supabase project URL
SUPABASE_URL=
# Supabase service role secret key (for admin operations)
SUPABASE_SERVICE_ROLE_KEY_SECRET=
# Supabase JWT secret (for token verification)
SUPABASE_JWT_SECRET=

# AI Configuration
# ----------------
# DeepSeek API key for chat completions
DEEPSEEK_API_KEY=

# Stripe Configuration
# --------------------
# Stripe secret key for API operations
STRIPE_SECRET_KEY=
# Stripe webhook secret for verifying webhook events
STRIPE_WEBHOOK_SECRET=
# Stripe price IDs for subscription plans (Light, Basic, Full, Heavy)
STRIPE_PRICE_ID_LIGHT=
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_FULL=
STRIPE_PRICE_ID_HEAVY=

# Frontend Configuration
# ----------------------
# Web portal URL (used for Stripe checkout redirects and email links)
WEB_PORTAL_URL=
# Web app URL (editor)
WEB_APP_URL=
# Comma-separated list of allowed CORS origins (for API access)
CORS_ALLOWED_ORIGINS=https://neoscribe-ai.com,https://app.neoscribe-ai.com,https://api.neoscribe-ai.com,http://localhost:3000,http://localhost:3001,http://localhost:8080

# Email Configuration
# ------------------
# Resend API key for sending emails
RESEND_KEY=
# From email address for claim token emails
EMAIL_FROM=

# GitHub Configuration
# --------------------
# GitHub download token for releases API
GITHUB_DOWNLOAD_TOKEN=
# GitHub repository owner
GITHUB_REPO_OWNER=
# GitHub repository name
GITHUB_REPO_NAME=

# Encryption Configuration
# ------------------------
# Encryption key for token links (64 hex characters / 32 bytes)
ENCRYPTION_KEY=



